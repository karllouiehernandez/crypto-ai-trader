# Jetson Nano 4GB — optimized .env template
# Copy to .env and fill in real values: cp deployment/jetson.env.example .env

# === Binance credentials ===
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# === Backtesting keys (separate testnet account, optional) ===
bkBINANCE_API_KEY=
bkBINANCE_API_SECRET=

# === Telegram ===
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === LLM — off by default; enable with OpenRouter (recommended for Jetson) ===
# OpenRouter is remote inference — only ~5-20MB overhead, no local GPU/CPU needed.
# To enable: set LLM_ENABLED=true and fill in OPENROUTER_API_KEY.
LLM_ENABLED=false
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=      # alternative provider
# GROQ_API_KEY=           # alternative provider

# === Jetson memory optimizations ===
# Reduce to 1 symbol to stay within 900MB RSS limit
MAX_SYMBOLS=1
# Use 90 days of history instead of 365 (faster cold start, less RAM)
DAYS_BACK=90
# Optional USB/local mirror for Binance Data Vision ZIP files.
# Example USB path: /media/jetson/USB/binance_history_cache
BINANCE_HISTORY_CACHE_DIR=/home/jetson/crypto_ai_trader/data/binance_history_cache

# === Market focus (disable heavy study on Jetson) ===
MARKET_FOCUS_UNIVERSE_SIZE=3
MARKET_FOCUS_TOP_N=2
MARKET_FOCUS_BACKTEST_DAYS=30

# === MCP server (for remote agent access via SSH tunnel) ===
MCP_API_KEY=change_this_to_a_strong_random_key
MCP_ALLOW_WRITES=false
MCP_TRANSPORT=sse
MCP_PORT=8765
MCP_HOST=127.0.0.1

# === Live trade gate (keep false until thoroughly paper-tested) ===
LIVE_TRADE_ENABLED=false
