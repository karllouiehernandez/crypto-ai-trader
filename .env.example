# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Live paper trading (run_live.py) ──────────────────────────────────────────
# Binance Testnet keys: https://testnet.binance.vision/
BINANCE_API_KEY=your_live_binance_api_key_here
BINANCE_API_SECRET=your_live_binance_api_secret_here

# Telegram Bot (for trade alerts and manual commands)
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Backtesting (run_backtest.py) ─────────────────────────────────────────────
# Can be the same testnet keys or a separate backtest account
bkBINANCE_API_KEY=your_backtest_binance_api_key_here
bkBINANCE_API_SECRET=your_backtest_binance_api_secret_here

# Historical data mirror cache.
# Leave unset to use ./data/binance_history_cache, or point this to USB/local storage on Jetson.
BINANCE_HISTORY_CACHE_DIR=
